# Net2Terraform Environment Configuration
# Copy this to .env and fill in your actual values

# ========== LLM API Keys (at least ONE is required) ==========
# Google Gemini API
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL_NAME=gemini-2.0-flash

# OpenRouter API
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL_NAME=google/gemma-3-4b-it:free

# Oxlo API
OXLO_API_KEY=your_oxlo_api_key_here
OXLO_URL=https://api.oxlo.ai/v1/chat/completions
OXLO_MODEL_NAME=gpt-4o-mini

# ========== LLM Provider Fallback Order (optional) ==========
# Comma-separated list of providers; tries each in order if one fails
CHAT_LLM_PROVIDERS=google,openrouter,oxlo
VISION_LLM_PROVIDERS=openrouter,oxlo

# ========== AI/ML Models & Paths (mostly optional with defaults) ==========
# YOLO object detection weights (default: best.pt)
YOLO_WEIGHTS=backend/best.pt

# Architecture rules PDF (default: backend/rules.pdf)
RULES_PDF_PATH=backend/rules.pdf

# PaddleOCR configuration
PADDLEOCR_LANG=en
PADDLEOCR_VERSION=PP-OCRv5
# PADDLEOCR_DEVICE=cpu  # Leave empty for auto-detection

# Tesseract OCR command (only set if non-standard location)
# TESSERACT_CMD=/path/to/tesseract

# ========== AWS Credentials (required if deploying to AWS) ==========
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_DEFAULT_REGION=us-east-1

# ========== Server Configuration (optional) ==========
# Port to run the FastAPI backend on (default: 8000)
PORT=8000

# ========== Terraform Deployment Directories (optional) ==========
# Where job-specific Terraform workspaces are stored
DEPLOYMENTS_DIR=backend/deployments
